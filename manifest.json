{
  "manifest_version": 3,
  "name": "Langester AI Co-Pilot",
  "version": "1.3",
  "description": "크롬 내장 Gemini Nano와 구글 워크스페이스를 결합한 프리미엄 로컬 AI 비서 워크스페이스",
  "permissions": [
    "sidePanel",
    "storage",
    "identity",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://studio.youtube.com/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
